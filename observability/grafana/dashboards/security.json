{
  "annotations": { "list": [] },
  "description": "Premium Security Monitoring Dashboard for NanoClaw",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total IPC Auth Failures",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(nanoclaw_ipc_auth_failures_total[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Rejected Mounts",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(nanoclaw_mount_requests_total{status=\"rejected\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"nanoclaw\"}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Active Containers",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "nanoclaw_active_containers",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["last"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "IPC Authorization Failures Over Time",
      "description": "Discrete number of blocked cross-group or unauthorized IPC actions",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "events", "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 2 },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "sum by (source_group) (increase(nanoclaw_ipc_auth_failures_total[$__interval]))",
          "legendFormat": "Failure: {{source_group}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } }
    },
    {
      "title": "Detailed Security Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": true,
      "panels": [
        {
          "title": "Mount Request Patterns",
          "description": "Volume of allowed vs rejected container mount requests",
          "type": "timeseries",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "palette-classic" },
              "custom": { "axisLabel": "requests", "drawStyle": "line", "fillOpacity": 15, "lineWidth": 1 },
              "unit": "none"
            }
          },
          "targets": [
            {
              "expr": "increase(nanoclaw_mount_requests_total{status=\"allowed\"}[$__interval])",
              "legendFormat": "Allowed",
              "refId": "A"
            },
            {
              "expr": "increase(nanoclaw_mount_requests_total{status=\"rejected\"}[$__interval])",
              "legendFormat": "Rejected",
              "refId": "B"
            }
          ],
          "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["nanoclaw", "security", "core"],
  "templating": {
    "list": [
      { "name": "DS_PROMETHEUS", "query": "prometheus", "type": "datasource" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "NanoClaw — Security & Observability",
  "version": 2
}

